#!/usr/bin/env bash
# neon — VoLTE ve VoNR (4G/5G) Test Ağı Yönetim CLI'ı
# KATMAN 1 (Okuyan Komutlar)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# lib/ dizini volte-repo içinden referans alınır.
LIB_DIR="${SCRIPT_DIR}/lib"

if [ -f "${LIB_DIR}/ayarlar.sh" ]; then
    source "${LIB_DIR}/ayarlar.sh"
    source "${LIB_DIR}/webui_api.sh"
    source "${LIB_DIR}/pyhss_api.sh"
else
    echo "[HATA] ayarlar.sh bulunamadı: ${LIB_DIR}/ayarlar.sh"
    exit 1
fi

# Docker yetki kontrolü
if ! docker ps >/dev/null 2>&1; then
    if ! sudo -n docker ps >/dev/null 2>&1; then
        echo "[HATA] Docker komutları için sudo yetkisi gerekiyor."
        echo "Lütfen scripti 'sudo ./neon' şeklinde çalıştırın."
        exit 1
    else
        DOCKER_CMD="sudo docker"
    fi
else
    DOCKER_CMD="docker"
fi

_calisan_containerlar() {
    $DOCKER_CMD ps --format '{{.Names}}' 2>/dev/null
}

cmd_status() {
    echo "════════ NEON 4G/5G AĞ DURUMU ════════"
    local names
    names=$(_calisan_containerlar)

    # Çekirdek Durumu
    if echo "$names" | grep -qx "amf"; then
        echo -e "[\033[0;32m✓\033[0m] 5G CORE AKTİF (sa-vonr-deploy.yaml)"
    elif echo "$names" | grep -qx "mme"; then
        echo -e "[\033[0;32m✓\033[0m] 4G CORE AKTİF (4g-volte-deploy.yaml)"
    else
        echo -e "[\033[0;31m✗\033[0m] ÇEKİRDEK: KAPALI"
    fi

    # Radyo Durumu
    if echo "$names" | grep -qx "srsgnb"; then
        echo -e "[\033[0;32m✓\033[0m] 5G RADYO (srsgnb) YAYINDA"
        local conf_file="${OPEN5GS_DIR}/srsran/gnb.yml"
        if [ -f "$conf_file" ]; then
            local arfcn=$(grep "dl_arfcn:" "$conf_file" | awk '{print $2}')
            local tx=$(grep "tx_gain:" "$conf_file" | awk '{print $2}')
            local mcc=$(grep "mcc:" "$conf_file" | head -1 | awk '{print $2}' | tr -d "'\"")
            local mnc=$(grep "mnc:" "$conf_file" | head -1 | awk '{print $2}' | tr -d "'\"")
            echo "    -> PLMN: ${mcc}${mnc} | ARFCN: ${arfcn} | TX GAIN: ${tx} (Software)"
        fi
    elif echo "$names" | grep -qx "srsenb"; then
        echo -e "[\033[0;32m✓\033[0m] 4G RADYO (srsenb) YAYINDA"
        local conf_file="${OPEN5GS_DIR}/srslte/enb.conf"
        if [ -f "$conf_file" ]; then
            local arfcn=$(grep "dl_earfcn" "$conf_file" | awk -F'=' '{print $2}' | tr -d ' ')
            local tx=$(grep "^tx_gain" "$conf_file" | awk -F'=' '{print $2}' | tr -d ' ')
            local mcc=$(grep "^mcc" "$conf_file" | awk -F'=' '{print $2}' | tr -d ' ')
            local mnc=$(grep "^mnc" "$conf_file" | awk -F'=' '{print $2}' | tr -d ' ')
            echo "    -> PLMN: ${mcc}${mnc} | EARFCN: ${arfcn} | TX GAIN: ${tx} (Software)"
        fi
    else
        echo -e "[\033[0;31m✗\033[0m] RADYO: KAPALI"
    fi
    echo "────────────────────────────────────────"
}

cmd_subscriber_show() {
    local net_type="${1:-}"
    local target_imsi="${2:-all}"

    if [[ "$net_type" != "4g" && "$net_type" != "5g" ]]; then
        echo "[HATA] Lütfen ağ türünü belirtin: 4g veya 5g"
        echo "Kullanım: ./neon subscriber show 4g|5g [IMSI]"
        exit 1
    fi

    echo "Aboneler taranıyor ($net_type)..."

    local core_container=""
    local attach_grep=""
    if [ "$net_type" = "4g" ]; then
        core_container="mme"
    else
        core_container="amf"
    fi

    # Çalışan core container'ı kontrol et
    if ! _calisan_containerlar | grep -qx "$core_container"; then
        echo "[!] $core_container container'ı şu an çalışmıyor ($net_type ağı kapalı)."
        return
    fi

    # Tüm IMSI'leri çıkar veya hedef IMSI kullan
    local imsi_list=""
    if [ "$target_imsi" = "all" ]; then
        # Loglardan "Registration complete" veya "Attach complete" satırlarındaki 15 haneli IMSI sayılarını çıkar
        if [ "$net_type" = "4g" ]; then
            imsi_list=$($DOCKER_CMD logs "$core_container" 2>&1 | grep -i "Attach complete" | grep -oE '[0-9]{15}' | sort -u || true)
        else
            imsi_list=$($DOCKER_CMD logs "$core_container" 2>&1 | grep -i "Registration complete" | grep -oE '[0-9]{15}' | sort -u || true)
        fi
    else
        imsi_list="$target_imsi"
    fi

    if [ -z "$imsi_list" ]; then
        echo "Loglarda eşleşen veya aktif abone bulunamadı."
        return
    fi

    echo "--------------------------------------------------------------------------------"
    printf "%-16s | %-12s | %-18s | %-25s\n" "IMSI" "AĞ" "ATTACH" "IMS REGISTER"
    echo "--------------------------------------------------------------------------------"

    for imsi in $imsi_list; do
        local attach_status="Başarısız"
        local ims_status="Başarısız"

        # Attach kontrolü
        if [ "$net_type" = "4g" ]; then
            if $DOCKER_CMD logs "$core_container" --tail 200 2>&1 | grep "$imsi" | grep -i "Attach complete" >/dev/null; then
                attach_status="Başarılı"
            fi
        else
            if $DOCKER_CMD logs "$core_container" --tail 200 2>&1 | grep "$imsi" | grep -i "Registration complete" >/dev/null; then
                attach_status="Başarılı"
            fi
        fi

        # IMS Register kontrolü (scscf)
        local scscf_last_state=""
        scscf_last_state=$($DOCKER_CMD logs scscf 2>&1 | grep "$imsi" | grep -iE "Contact valid|Contact expired|Bogus state|Contact deleted|delayed delete" | tail -1 || true)

        if echo "$scscf_last_state" | grep -i "Contact valid" >/dev/null; then
            ims_status="Başarılı (200 OK)"
        elif [ -n "$scscf_last_state" ]; then
            ims_status="Kararsız (Süresi doldu/Koptu)"
        else
            ims_status="Başarısız"
        fi

        printf "%-16s | %-12s | %-18s | %-25s\n" "$imsi" "${net_type^^} (${core_container})" "$attach_status" "$ims_status"
    done
    echo "--------------------------------------------------------------------------------"
}

cmd_subscriber_set_msisdn() {
    local imsi="${1:-}"
    local yeni_msisdn="${2:-}"

    if [ -z "$imsi" ] || [ -z "$yeni_msisdn" ]; then
        echo "[HATA] Kullanım: ./neon subscriber set-msisdn <IMSI> <YENI_MSISDN>"
        exit 1
    fi

    echo "[$imsi] için MSISDN $yeni_msisdn olarak güncelleniyor..."

    # 1. Abone sistemde var mı?
    if ! webui_abone_var_mi "$imsi"; then
        echo "[HATA] Abone ($imsi) sistemde bulunamadı."
        echo "Önce 'subscriber add' kullanarak aboneyi ekleyin."
        exit 1
    fi

    # 2. MSISDN'i İki HSS'te de güncelle
    local basarili=0
    
    echo "-> 1/2: EPC (WebUI/MongoDB) Güncelleniyor..."
    if webui_msisdn_guncelle "$imsi" "$yeni_msisdn"; then
        basarili=$((basarili + 1))
    fi

    echo "-> 2/2: IMS (pyHSS/MySQL) Güncelleniyor..."
    if pyhss_msisdn_guncelle "$imsi" "$yeni_msisdn"; then
        basarili=$((basarili + 1))
    fi

    # 3. Sonuç ve Uyarı
    if [ "$basarili" -eq 2 ]; then
        echo "────────────────────────────────────────"
        echo -e "[\033[0;32m✓\033[0m] İşlem Başarılı! MSISDN her iki sistemde de güncellendi."
        echo -e "[\033[0;33m!\033[0m] KRİTİK UYARI: Değişikliğin ağa yansıması için telefonunuzu Uçak Modu'na alıp tekrar çıkarın (Yeniden Register)."
        echo "Çağrı ve SMS işlemleri yeni MSISDN ($yeni_msisdn) ile yapılabilecektir."
        echo "────────────────────────────────────────"
    else
        echo "[HATA] Güncelleme eksik tamamlandı. Lütfen çıktıları kontrol edin."
    fi
}

cmd_subscriber_add() {
    local imsi="" ki="" opc="" msisdn="" amf="" sqn="" net_type="5g"
    
    while [ $# -gt 0 ]; do
        case "$1" in
            --imsi) imsi="$2"; shift 2 ;;
            --ki) ki="$2"; shift 2 ;;
            --opc) opc="$2"; shift 2 ;;
            --msisdn) msisdn="$2"; shift 2 ;;
            --amf) amf="$2"; shift 2 ;;
            --sqn) sqn="$2"; shift 2 ;;
            --4g) net_type="4g"; shift 1 ;;
            --5g) net_type="5g"; shift 1 ;;
            *) echo "[HATA] Bilinmeyen parametre: $1"; exit 1 ;;
        esac
    done

    if [ -z "$imsi" ] || [ -z "$ki" ] || [ -z "$opc" ] || [ -z "$msisdn" ]; then
        echo "[HATA] Eksik parametre! --imsi, --ki, --opc ve --msisdn zorunludur."
        echo "Kullanım: ./neon subscriber add --imsi X --ki Y --opc Z --msisdn M [--4g|--5g]"
        exit 1
    fi

    # 5G UDM/UDR ek alanları: Mevcut webui_abone_ekle fonksiyonu zaten Faz 4 
    # doğrulanmış tam VoLTE/VoNR APN (internet + ims) şemasını sst:1 ile kullanıyor.
    # Uydurma alan eklenmeden kanıtlanmış lib/ fonksiyonu çağrılır.
    echo "[$imsi] Abone $net_type ağı için ekleniyor..."

    echo "-> 1/2: EPC/5GC (WebUI/MongoDB) Ekleniyor..."
    webui_abone_ekle "$imsi" "$ki" "$opc" "$msisdn" "$amf" "$sqn" || { echo "[HATA] WebUI ekleme başarısız!"; exit 1; }

    echo "-> 2/2: IMS (pyHSS/MySQL) Ekleniyor..."
    pyhss_kart_ekle "$imsi" "$ki" "$opc" "$msisdn" || { echo "[HATA] pyHSS ekleme başarısız!"; exit 1; }

    echo "────────────────────────────────────────"
    echo -e "[\033[0;32m✓\033[0m] İşlem Başarılı! Abone her iki sisteme eklendi."
    echo "────────────────────────────────────────"
}

cmd_subscriber_del() {
    local imsi="" net_type="5g"
    
    while [ $# -gt 0 ]; do
        case "$1" in
            --imsi) imsi="$2"; shift 2 ;;
            --4g) net_type="4g"; shift 1 ;;
            --5g) net_type="5g"; shift 1 ;;
            *) echo "[HATA] Bilinmeyen parametre: $1"; exit 1 ;;
        esac
    done

    if [ -z "$imsi" ]; then
        echo "[HATA] Eksik parametre! --imsi zorunludur."
        exit 1
    fi

    echo -n "[$imsi] abonesini SİLMEK üzeresiniz! Telefon ağdan düşecek. Emin misiniz? (e/h): "
    read -r onay
    if [ "$onay" != "e" ]; then
        echo "İşlem iptal edildi."
        exit 0
    fi

    echo "-> 1/2: EPC/5GC (WebUI/MongoDB) Siliniyor..."
    webui_abone_sil "$imsi" || true

    echo "-> 2/2: IMS (pyHSS/MySQL) Siliniyor..."
    pyhss_kart_sil "$imsi" || true

    echo "────────────────────────────────────────"
    echo -e "[\033[0;32m✓\033[0m] Abone başarıyla silindi."
    echo "────────────────────────────────────────"
}

# KATMAN 2 — start/stop
cmd_start() {
    local net_type="${1:-}"
    local comp="${2:-}"
    local force_flag="${3:-}"

    if [[ "$net_type" != "4g" && "$net_type" != "5g" ]]; then
        echo "[HATA] Kullanım: ./neon start 4g|5g core|radyo|all [--force]"
        exit 1
    fi

    if [[ "$comp" != "core" && "$comp" != "radyo" && "$comp" != "all" ]]; then
        echo "[HATA] Kullanım: ./neon start 4g|5g core|radyo|all [--force]"
        exit 1
    fi

    # Geçiş Güvenliği (KRİTİK)
    if [ "$net_type" = "5g" ] && [[ "$comp" == "core" || "$comp" == "all" ]]; then
        if _calisan_containerlar | grep -qx "mme"; then
            if [ "$force_flag" = "--force" ]; then
                echo "4G kapatılıyor (--force)..."
                (cd "${OPEN5GS_DIR}" && $DOCKER_CMD compose -f 4g-volte-deploy.yaml down)
            else
                echo "HATA: 4G aktif. Önce './neon stop 4g all' veya '--force' kullan."
                exit 1
            fi
        fi
    elif [ "$net_type" = "4g" ] && [[ "$comp" == "core" || "$comp" == "all" ]]; then
        if _calisan_containerlar | grep -qx "amf"; then
            if [ "$force_flag" = "--force" ]; then
                echo "5G kapatılıyor (--force)..."
                (cd "${OPEN5GS_DIR}" && $DOCKER_CMD compose -f sa-vonr-deploy.yaml down)
            else
                echo "HATA: 5G aktif. Önce './neon stop 5g all' veya '--force' kullan."
                exit 1
            fi
        fi
    fi

    cd "${OPEN5GS_DIR}" || exit 1
    if [ "$net_type" = "4g" ]; then
        if [[ "$comp" == "core" || "$comp" == "all" ]]; then
            echo "4G Core başlatılıyor..."
            $DOCKER_CMD compose -f 4g-volte-deploy.yaml up -d
            
            sed -i 's|^#!define WITH_N5|##!define WITH_N5|' "${OPEN5GS_DIR}/pcscf/pcscf.cfg" || true
            sed -i 's|^##!define WITH_RX|#!define WITH_RX|' "${OPEN5GS_DIR}/pcscf/pcscf.cfg" || true
            $DOCKER_CMD restart pcscf || true
            echo "pcscf 4G (Rx/PCRF) moduna alındı"
        fi
        if [[ "$comp" == "radyo" || "$comp" == "all" ]]; then
            echo "4G Radyo başlatılıyor..."
            $DOCKER_CMD compose -f srsenb.yaml up -d
        fi
    elif [ "$net_type" = "5g" ]; then
        if [[ "$comp" == "core" || "$comp" == "all" ]]; then
            echo "5G Core başlatılıyor..."
            $DOCKER_CMD compose -f sa-vonr-deploy.yaml up -d
            
            sed -i 's|^#!define WITH_RX|##!define WITH_RX|' "${OPEN5GS_DIR}/pcscf/pcscf.cfg" || true
            sed -i 's|^##!define WITH_N5|#!define WITH_N5|' "${OPEN5GS_DIR}/pcscf/pcscf.cfg" || true
            $DOCKER_CMD restart pcscf || true
            echo "pcscf 5G (N5/PCF) moduna alındı"
        fi
        if [[ "$comp" == "radyo" || "$comp" == "all" ]]; then
            echo "5G Radyo başlatılıyor..."
            $DOCKER_CMD compose -f srsgnb.yaml up -d
        fi
    fi
}

cmd_stop() {
    local net_type="${1:-}"
    local comp="${2:-}"

    if [[ "$net_type" != "4g" && "$net_type" != "5g" ]]; then
        echo "[HATA] Kullanım: ./neon stop 4g|5g core|radyo|all"
        exit 1
    fi

    if [[ "$comp" != "core" && "$comp" != "radyo" && "$comp" != "all" ]]; then
        echo "[HATA] Kullanım: ./neon stop 4g|5g core|radyo|all"
        exit 1
    fi

    cd "${OPEN5GS_DIR}" || exit 1
    echo "NOT: 'down' işlemi veritabanı (volume) verisini SİLMEZ. Güvenlidir."
    if [ "$net_type" = "4g" ]; then
        if [[ "$comp" == "radyo" || "$comp" == "all" ]]; then
            echo "4G Radyo durduruluyor..."
            $DOCKER_CMD compose -f srsenb.yaml down
        fi
        if [[ "$comp" == "core" || "$comp" == "all" ]]; then
            echo "4G Core durduruluyor..."
            $DOCKER_CMD compose -f 4g-volte-deploy.yaml down
        fi
    elif [ "$net_type" = "5g" ]; then
        if [[ "$comp" == "radyo" || "$comp" == "all" ]]; then
            echo "5G Radyo durduruluyor..."
            $DOCKER_CMD compose -f srsgnb.yaml down
        fi
        if [[ "$comp" == "core" || "$comp" == "all" ]]; then
            echo "5G Core durduruluyor..."
            $DOCKER_CMD compose -f sa-vonr-deploy.yaml down
        fi
    fi
}

# KATMAN 3 — calibrate
cmd_calibrate() {
    local net_type="${1:-}"
    local param="${2:-}"
    shift 2

    if [[ "$net_type" != "4g" && "$net_type" != "5g" ]]; then
        echo "[HATA] Kullanım: ./neon calibrate 4g|5g power|arfcn|plmn [değerler]"
        exit 1
    fi

    local conf_file=""
    local compose_file=""
    if [ "$net_type" = "4g" ]; then
        conf_file="${OPEN5GS_DIR}/srslte/enb.conf"
        compose_file="srsenb.yaml"
    else
        conf_file="${OPEN5GS_DIR}/srsran/gnb.yml"
        compose_file="srsgnb.yaml"
    fi

    if [ ! -f "$conf_file" ]; then
        echo "[HATA] Config dosyası bulunamadı: $conf_file"
        exit 1
    fi

    local do_restart=0

    if [ "$param" = "power" ]; then
        local current_tx=""
        if [ "$net_type" = "4g" ]; then
            current_tx=$(grep "^tx_gain" "$conf_file" | awk -F'=' '{print $2}' | tr -d ' ')
        else
            current_tx=$(grep "tx_gain:" "$conf_file" | awk '{print $2}')
        fi
        echo "Mevcut tx_gain: $current_tx (software gain 0-89, gerçek dBm DEĞİL)"
        echo -n "Yeni değer girin: "
        read -r new_tx

        echo -n "Bu işlem yayını yeniden başlatır, bağlı telefonlar düşer. Devam? (e/h): "
        read -r onay
        if [ "$onay" != "e" ]; then
            echo "İptal edildi."
            exit 0
        fi

        cp "$conf_file" "${conf_file}.bak"
        if [ "$net_type" = "4g" ]; then
            sed -i "s/^tx_gain.*/tx_gain = $new_tx/" "$conf_file"
        else
            sed -i "s/^\([[:space:]]*\)tx_gain:.*/\1tx_gain: $new_tx/" "$conf_file"
        fi
        do_restart=1

    elif [ "$param" = "arfcn" ]; then
        local new_arfcn="${1:-}"
        if [ -z "$new_arfcn" ]; then
            echo "[HATA] Kullanım: ./neon calibrate $net_type arfcn <deger>"
            exit 1
        fi

        echo -n "Bu işlem yayını yeniden başlatır, bağlı telefonlar düşer. Devam? (e/h): "
        read -r onay
        if [ "$onay" != "e" ]; then
            echo "İptal edildi."
            exit 0
        fi

        cp "$conf_file" "${conf_file}.bak"
        if [ "$net_type" = "4g" ]; then
            sed -i "s/^dl_earfcn.*/dl_earfcn = $new_arfcn/" "$conf_file"
        else
            sed -i "s/^\([[:space:]]*\)dl_arfcn:.*/\1dl_arfcn: $new_arfcn/" "$conf_file"
        fi
        do_restart=1

    elif [ "$param" = "plmn" ]; then
        local mcc=""
        local mnc=""
        while [ $# -gt 0 ]; do
            case "$1" in
                -mcc) mcc="$2"; shift 2 ;;
                -mnc) mnc="$2"; shift 2 ;;
                *) echo "Bilinmeyen parametre: $1"; exit 1 ;;
            esac
        done

        if [ -z "$mcc" ] || [ -z "$mnc" ]; then
            echo "[HATA] Kullanım: ./neon calibrate $net_type plmn -mcc X -mnc Y"
            exit 1
        fi
        if ! [[ "$mcc" =~ ^[0-9]{3}$ && "$mnc" =~ ^[0-9]{3}$ ]]; then
            echo "[HATA] MCC 3 hane, MNC 3 hane olmalıdır (örn. mnc 001)."
            exit 1
        fi

        echo -n "Bu işlem yayını yeniden başlatır, bağlı telefonlar düşer. Devam? (e/h): "
        read -r onay
        if [ "$onay" != "e" ]; then
            echo "İptal edildi."
            exit 0
        fi

        cp "$conf_file" "${conf_file}.bak"
        if [ "$net_type" = "4g" ]; then
            sed -i "s/^mcc.*/mcc = $mcc/" "$conf_file"
            sed -i "s/^mnc.*/mnc = $mnc/" "$conf_file"
        else
            sed -i "s/^\([[:space:]]*\)mcc:.*/\1mcc: '$mcc'/" "$conf_file"
            sed -i "s/^\([[:space:]]*\)mnc:.*/\1mnc: '$mnc'/" "$conf_file"
        fi
        do_restart=1
    else
        echo "[HATA] Bilinmeyen calibrate parametresi: $param"
        echo "Kullanım: ./neon calibrate 4g|5g power|arfcn|plmn [değerler]"
        exit 1
    fi

    if [ $do_restart -eq 1 ]; then
        echo "Radyo ($compose_file) yeniden başlatılıyor..."
        (cd "${OPEN5GS_DIR}" && $DOCKER_CMD compose -f "$compose_file" restart)
        echo "Yeni değerler uygulandı."
    fi
}

main() {
    if [ $# -eq 0 ]; then
        echo "Kullanım:"
        echo "  ./neon status"
        echo "  ./neon start 4g|5g core|radyo|all [--force]"
        echo "  ./neon stop 4g|5g core|radyo|all"
        echo "  ./neon calibrate 4g|5g power|arfcn|plmn [degerler]"
        echo "  ./neon subscriber show 4g|5g [IMSI]"
        echo "  ./neon subscriber set-msisdn <IMSI> <YENI_MSISDN>"
        echo "  ./neon subscriber add --imsi X --ki Y --opc Z --msisdn M [--4g|--5g]"
        echo "  ./neon subscriber del --imsi X [--4g|--5g]"
        exit 1
    fi

    local cmd="$1"; shift

    case "$cmd" in
        status)
            cmd_status
            ;;
        start)
            cmd_start "$@"
            ;;
        stop)
            cmd_stop "$@"
            ;;
        calibrate)
            cmd_calibrate "$@"
            ;;
        subscriber)
            local subcmd="${1:-}"
            if [ "$subcmd" = "show" ]; then
                shift
                cmd_subscriber_show "${1:-}" "${2:-all}"
            elif [ "$subcmd" = "set-msisdn" ]; then
                shift
                cmd_subscriber_set_msisdn "${1:-}" "${2:-}"
            elif [ "$subcmd" = "add" ]; then
                shift
                cmd_subscriber_add "$@"
            elif [ "$subcmd" = "del" ]; then
                shift
                cmd_subscriber_del "$@"
            else
                echo "[HATA] Bilinmeyen alt komut: subscriber $subcmd"
                exit 1
            fi
            ;;
        *)
            echo "[HATA] Bilinmeyen komut: $cmd"
            exit 1
            ;;
    esac
}

main "$@"
